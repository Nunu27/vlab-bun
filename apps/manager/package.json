{
	"name": "@vlab/manager",
	"version": "1.0.50",
	"exports": {
		".": "./src/index.ts",
		"./server": "./src/server.ts"
	},
	"scripts": {
		"dev": "bun run --watch src/index.ts serve | pino-pretty",
		"seed": "bun run src/index.ts seed | pino-pretty",
		"build": "bun build src/index.ts --compile --minify --sourcemap --outfile ../../out/app && cp -r migrations ../../out/migrations",
		"typecheck": "tsc --noEmit",
		"drizzle:generate": "drizzle-kit generate",
		"drizzle:migrate": "drizzle-kit migrate",
		"drizzle:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@bogeychan/elysia-logger": "^0.1.10",
		"@elysiajs/openapi": "^1.4.14",
		"@elysiajs/static": "^1.4.9",
		"@jawit/common": "workspace:*",
		"@jawit/elysia-caching": "workspace:*",
		"@jawit/paginator": "workspace:*",
		"@msgpack/msgpack": "^3.1.3",
		"@sinclair/typebox": "^0.34.49",
		"@socket.io/bun-engine": "^0.1.0",
		"@socket.io/redis-adapter": "^8.3.0",
		"@vlab/evaluator": "workspace:*",
		"@vlab/grpc": "workspace:*",
		"@vlab/shared": "workspace:*",
		"@vlab/ws": "workspace:*",
		"bcryptjs": "^2.4.3",
		"croner": "^10.0.1",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"elysia": "1.4.28",
		"elysia-helmet": "^3.0.0",
		"fast-xml-parser": "^5.5.9",
		"guacamole-lite": "^1.2.0",
		"ioredis": "^5.4.1",
		"nice-grpc": "^2.1.10",
		"node-pty": "^1.0.0",
		"pino": "^10.3.1",
		"s3mini": "^0.9.2",
		"socket.io": "^4.8.3",
		"socket.io-msgpack-parser": "^3.0.2"
	},
	"devDependencies": {
		"@types/bun": "1.3.11",
		"@types/ws": "^8.18.1",
		"drizzle-kit": "^0.31.10"
	},
	"module": "src/index.js"
}
