{
  "name": "vlab-backend",
  "version": "1.0.50",
  "main": "src/index.ts",
  "exports": {
    "./server": "./src/services/server.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts | pino-pretty",
    "build": "bun build src/index.ts --compile --minify --sourcemap --outfile ../../build/vlab --external cpu-features && cp -r migrations ../../build/migrations",
    "seed": "bun run src/seeder/index.ts | pino-pretty",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/openapi": "^1.4.11",
    "@elysiajs/static": "^1.4.7",
    "@msgpack/msgpack": "^3.1.2",
    "@socket.io/bun-engine": "^0.1.0",
    "@socket.io/redis-streams-adapter": "^0.2.3",
    "@vlab/monitor": "workspace:*",
    "@vlab/shared": "workspace:*",
    "croner": "6.0.7",
    "dockerode": "^4.0.9",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.18",
    "elysia-helmet": "^3.0.0",
    "fast-xml-parser": "^5.3.2",
    "guacamole-lite": "^1.2.0",
    "ioredis": "^5.8.2",
    "openapi-fetch": "^0.15.0",
    "openapi-typescript-helpers": "^0.0.15",
    "pg": "^8.16.3",
    "pg-native": "^3.5.2",
    "pino": "^10.1.0",
    "redis": "^5.10.0",
    "s3mini": "^0.7.1",
    "socket.io": "^4.8.1",
    "socket.io-msgpack-parser": "^3.0.2",
    "typebox": "^1.0.61"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.47",
    "@types/pg": "^8.15.6",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8"
  }
}