{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "ES2020"],
    "jsx": "react-jsx",
    "target": "ES2020",
    "noEmit": true,
    "useDefineForClassFields": true,

    /* modules */
    "module": "ESNext",
    "moduleDetection": "force",
    "noUncheckedSideEffectImports": true,
    "types": ["bun-types"]
  },
  "include": ["src", "../backend/src/guacamole-lite.d.ts"]
}
