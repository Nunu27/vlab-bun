		"@vlab/evaluator": "workspace:*",
		"@vlab/grpc": "workspace:*",
		"@vlab/shared": "workspace:*",
		"dockerode": "^5.0.0",
		"dotenv": "^17.3.1",
		"nice-grpc": "^2.1.16",
		"nice-grpc-common": "^2.0.3",
		"pino": "^10.3.1"
	},
	"devDependencies": {
		"@types/bun": "1.3.11",
