import type { MaybePromise } from "bun";
import { Type as t, type TProperties, type Static } from "typebox";

export interface Trigger<TContext, TData extends TProperties> {
	data: TData;
	handler: (
		ctx: TContext,
		callback: (data: Static<TData>) => MaybePromise<void>
	) => MaybePromise<void>;
}

export interface Checker<
	TParams extends TProperties,
	TTriggers extends Record<string, TProperties>,
	TTrigger extends keyof TTriggers
> {
	trigger: TTrigger;
	params: TParams;
	handler: (ctx: { params: Static<TParams>; data: Static<TTriggers[TTrigger]> }) => boolean;
}

export interface Evaluator<
	TContext extends Record<string, any> = Record<string, any>,
	TFullContext = TContext & { node: { id: string } },
	TTriggers extends Record<string, Trigger<TFullContext, any>> = Record<
		string,
		Trigger<TFullContext, any>
	>,
	TCheckers extends Record<
		string,
		Checker<any, { [key in keyof TTriggers]: TTriggers[key]["data"] }, any>
	> = {}
> {
	context(): TContext;
	dipose: (ctx: TFullContext) => MaybePromise<void>;
	triggers: TTriggers;
	checkers: TCheckers;
}

// Helper function to create type-safe triggers
export function createTrigger<TData extends TProperties>(
	data: TData
) {
	return <TContext>(
		handler: (
			ctx: TContext,
			callback: (data: Static<TData>) => MaybePromise<void>
		) => MaybePromise<void>
	): Trigger<TContext, TData> => {
		return { data, handler };
	};
}

// Helper function to create type-safe checkers
export function createChecker<
	TTriggers extends Record<string, TProperties>,
	TTrigger extends keyof TTriggers,
	TParams extends TProperties
>(
	trigger: TTrigger,
	params: TParams,
	handler: (ctx: { params: Static<TParams>; data: Static<TTriggers[TTrigger]> }) => boolean
): Checker<TParams, TTriggers, TTrigger> {
	return { trigger, params, handler };
}

// Helper to infer trigger data types from trigger definitions
type InferTriggerData<T> = T extends {
	data: infer D extends TProperties;
	handler: any;
}
	? D
	: never;

type ExtractTriggersData<TTriggers> = {
	[K in keyof TTriggers]: InferTriggerData<TTriggers[K]>;
};

// Helper function to create type-safe evaluators with proper inference
export function createEvaluator<const T>(
	config: T extends {
		context: () => infer TContext extends Record<string, any>;
		dipose: any;
		triggers: infer TTriggers;
	}
		? {
				context: () => TContext;
				dipose: (ctx: TContext & { node: { id: string } }) => MaybePromise<void>;
				triggers: {
					[K in keyof TTriggers]: TTriggers[K] extends { data: infer D extends TProperties }
						? {
								data: D;
								handler: (
									ctx: TContext & { node: { id: string } },
									callback: (data: Static<D>) => MaybePromise<void>
								) => MaybePromise<void>;
						  }
						: never;
				};
				checkers?: {
					[CK in string]: TTriggers extends Record<string, { data: infer _ }>
						? {
								trigger: keyof TTriggers;
								params: TProperties;
								handler: <TK extends keyof TTriggers>(
									ctx: TTriggers[TK] extends { data: infer TD extends TProperties }
										? {
												params: Static<TProperties>;
												data: Static<TD>;
										  }
										: never
								) => boolean;
						  }
						: never;
				};
		  }
		: never
) {
	return config;
}

// Example usage with type safety
const tes = createEvaluator({
	context() {
		return { foo: "bar" as const };
	},
	dipose(ctx) {
		// ctx is properly typed as { foo: "bar" } & { node: { id: string } }
		console.log(ctx.foo, ctx.node.id);
	},
	triggers: {
		tes: {
			data: {
				tes: t.String(),
				num: t.Number()
			},
			handler(ctx, callback) {
				// ctx is now properly typed as { foo: "bar" } & { node: { id: string } }
				console.log(ctx.foo, ctx.node.id);
				
				// callback parameter is now fully typed as (data: { tes: string; num: number }) => ...
				callback({
					tes: "hello",
					num: 42
				});

				// This would be a type error:
				// callback({ tes: 123, num: 42 }); // Error: tes should be string
				// callback({ tes: "hello" }); // Error: missing num property
			}
		}
	}
});
