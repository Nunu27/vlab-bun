{
	"name": "@vlab/grpc",
	"module": "src/index.ts",
	"exports": "./src/index.ts",
	"type": "module",
	"scripts": {
		"build": "grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src --ts_proto_opt=outputServices=nice-grpc,outputServices=generic-definitions,useExactTypes=false,esModuleInterop=true -I=./proto proto/*.proto"
	},
	"devDependencies": {
		"@bufbuild/protobuf": "^2.12.0",
		"@types/bun": "1.3.11",
		"grpc-tools": "^1.13.1",
		"ts-proto": "^2.11.8"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@sinclair/typebox": "^0.34.49",
		"long": "^5.3.2",
		"nice-grpc": "^2.1.16",
		"nice-grpc-common": "^2.0.3",
		"protobufjs": "^8.6.1",
		"waycast": "^1.1.5"
	}
}
