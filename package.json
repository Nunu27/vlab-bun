{
  "name": "vlab",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun frontend dev & bun backend dev",
    "build": "bun frontend build && bun backend build",
    "lint": "bun lint",
    "frontend": "bun run --filter vlab-frontend",
    "backend": "bun run --filter vlab-backend",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/frontend/**/*.{ts,tsx,js,jsx,json,css,md}": [
      "bun run --filter vlab-frontend format:staged"
    ],
    "apps/frontend/**/*.{ts,tsx,js,jsx}": [
      "bun run --filter vlab-frontend lint:staged --fix"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "peerDependencies": {},
  "trustedDependencies": [
    "core-js",
    "protobufjs"
  ]
}