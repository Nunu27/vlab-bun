{
	"name": "vlab",
	"module": "index.ts",
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bun": "^1.3.14",
		"compose-spec-schema": "^1.0.0",
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^6.0.3"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css}": [
			"biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"private": true,
	"scripts": {
		"dev": "concurrently -n web,manager -c cyan,magenta \"bun web dev\" \"bun manager dev\"",
		"web": "bun --filter @vlab/web",
		"manager": "bun --filter @vlab/manager",
		"check": "biome check --write .",
		"check:ci": "biome check .",
		"lint": "biome lint --write --unsafe .",
		"format": "biome format --write .",
		"typecheck": "bun --filter='*' run typecheck",
		"prepare": "husky"
	},
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*/*"
	]
}
