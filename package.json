{
	"name": "vlab",
	"module": "index.ts",
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bun": "latest",
		"compose-spec-schema": "^1.0.0",
		"concurrently": "^9.2.1",
		"lint-staged": "^16.4.0",
		"simple-git-hooks": "^2.13.1"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css}": [
			"biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"private": true,
	"scripts": {
		"dev": "concurrently -n web,api -c cyan,magenta \"bun web dev\" \"bun api dev\"",
		"web": "bun --filter @vlab/web",
		"api": "bun --filter @vlab/api",
		"check": "biome check --write .",
		"check:ci": "biome check .",
		"lint": "biome lint --write --unsafe .",
		"format": "biome format --write .",
		"typecheck": "bun --filter='*' run typecheck",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "bunx lint-staged",
		"pre-push": "bun --filter='*' run typecheck"
	},
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*/*"
	]
}
