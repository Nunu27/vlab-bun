      "seed": 860856640,
      "version": 1523,
      "versionNonce": 1257699648,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783538707189,
      "link": null,
      "locked": false,
      "text": "• Mengimplementasikan platform\n   virtual lab dengan Docker yang\n   dapat diskalakan secara\n   horizontal\n• Membuat sistem evaluasi\n   otomatis dengan feedback\n   real-time\n• Menyediakan akses ke perangkat\n   lab secara langsung melalui\n   browser\n• Membuat editor visual untuk\n   topologi dan penilaian",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Mengimplementasikan platform\n   virtual lab dengan Docker yang\n   dapat diskalakan secara\n   horizontal\n• Membuat sistem evaluasi\n   otomatis dengan feedback\n   real-time\n• Menyediakan akses ke perangkat\n   lab secara langsung melalui\n   browser\n• Membuat editor visual untuk\n   topologi dan penilaian",
      "autoResize": false,
      "lineHeight": 1.35
    },
