      "isDeleted": false,
      "boundElements": null,
      "updated": 1783538749227,
      "link": null,
      "locked": false,
      "text": "• Penggunaan storage 1.157x   \n   lebih efisien dari pada\n   menggunakan VM\n• Platform berhasil diskalakan\n   secara horizontal menggunakan\n   VPS Azure dan juga Oracle",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Penggunaan storage 1.157x   \n   lebih efisien dari pada\n   menggunakan VM\n• Platform berhasil diskalakan\n   secara horizontal menggunakan\n   VPS Azure dan juga Oracle",
      "autoResize": false,
      "lineHeight": 1.35
    },
