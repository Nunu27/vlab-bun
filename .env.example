# Production Environment Variables for VPS
# Copy this file to /opt/vlab/.env on your VPS and update the values

# Database Configuration (External)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://vlab:your_secure_password@your-db-host:5432/vlab

# Redis Configuration (External)
# Format: redis://host:port or redis://:password@host:port
REDIS_URL=redis://your-redis-host:6379

# Docker Networks (comma-separated, default: bridge)
# Examples:
#   DOCKER_NETWORKS=bridge
#   DOCKER_NETWORKS=proxy,bridge
#   DOCKER_NETWORKS=my-network
DOCKER_NETWORKS=proxy,bridge

# Application Configuration
# BIND_PORT=8080  # Optional: Port to bind container (if not set, no port binding)
SESSION_TTL=10800

# Batching Configuration
BATCH_SIZE=100
DEBOUNCE_MS=100
MAX_BATCH_WAIT_MS=500

# URLs
BASE_URL=https://your-domain.com
CAS_BASE_URL=https://your-cas-server.com/cas

# Reverse Proxy (if using nginx-proxy or similar)
VIRTUAL_HOST=your-domain.com
# LETSENCRYPT_HOST=your-domain.com
# LETSENCRYPT_EMAIL=admin@your-domain.com
